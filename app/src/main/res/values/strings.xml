    <string name="onboarding_title_one">Inspect with a clear process</string>
    <string name="onboarding_body_one">Guided automatic readings and manual checks help you assess phones, tablets, trade-ins, and repair intake devices.</string>
    <string name="onboarding_title_two">You make the final judgement</string>
    <string name="onboarding_body_two">Android can expose hardware readings, but display quality, sound clarity, physical damage, and future reliability require human observation.</string>
    <string name="onboarding_title_three">Private and offline</string>
    <string name="onboarding_body_three">Inspection data stays on this device. Nothing is uploaded. Export or share happens only when you choose it.</string>
    <string name="onboarding_title_four">Important limitations</string>
    <string name="onboarding_body_four">This is not manufacturer certification. Android restrictions or missing hardware can prevent tests. IMEI and serial numbers are never retrieved automatically.</string>
    <string name="privacy_summary">No account, analytics, ads, backend, or tracking. Google Play processes lifetime-upgrade purchases.</string>
    <string name="get_started">Get started</string>

