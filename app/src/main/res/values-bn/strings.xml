    <string name="onboarding_title_one">সুশৃঙ্খলভাবে ডিভাইস পরীক্ষা করুন</string>
    <string name="onboarding_body_one">স্বয়ংক্রিয় রিডিং ও নির্দেশিত যাচাইয়ের মাধ্যমে ফোন, ট্যাবলেট, ট্রেড-ইন এবং মেরামতের ডিভাইস মূল্যায়ন করুন।</string>
    <string name="onboarding_title_two">চূড়ান্ত সিদ্ধান্ত আপনার</string>
    <string name="onboarding_body_two">Android হার্ডওয়্যার রিডিং দিতে পারে, তবে ডিসপ্লে, শব্দ, বাহ্যিক ক্ষতি ও ভবিষ্যৎ নির্ভরযোগ্যতা মানুষের পর্যবেক্ষণেই যাচাই করতে হয়।</string>
    <string name="onboarding_title_three">ব্যক্তিগত ও অফলাইন</string>
    <string name="onboarding_body_three">পরিদর্শনের তথ্য এই ডিভাইসেই থাকে। কিছু আপলোড হয় না। শুধু আপনার নির্দেশে এক্সপোর্ট বা শেয়ার হয়।</string>
    <string name="onboarding_title_four">গুরুত্বপূর্ণ সীমাবদ্ধতা</string>
    <string name="onboarding_body_four">এটি নির্মাতার সনদ নয়। Android-এর সীমাবদ্ধতা বা হার্ডওয়্যারের অনুপস্থিতিতে কিছু পরীক্ষা সম্ভব নাও হতে পারে। IMEI ও সিরিয়াল কখনো স্বয়ংক্রিয়ভাবে নেওয়া হয় না।</string>
    <string name="privacy_summary">কোনো অ্যাকাউন্ট, অ্যানালিটিক্স, বিজ্ঞাপন, সার্ভার বা ট্র্যাকিং নেই। আজীবন আপগ্রেডের অর্থপ্রদান Google Play পরিচালনা করে।</string>
    <string name="get_started">শুরু করুন</string>

